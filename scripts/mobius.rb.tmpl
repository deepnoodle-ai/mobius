class Mobius < Formula
  desc "CLI for the Mobius workflow orchestration platform"
  homepage "https://www.mobiusops.ai/"
  version "{{VERSION}}"
  license "Apache-2.0"

  on_macos do
    if Hardware::CPU.arm?
      url "https://github.com/deepnoodle-ai/mobius/releases/download/v{{VERSION}}/mobius-darwin-arm64"
      sha256 "{{SHA_DARWIN_ARM64}}"
    else
      url "https://github.com/deepnoodle-ai/mobius/releases/download/v{{VERSION}}/mobius-darwin-amd64"
      sha256 "{{SHA_DARWIN_AMD64}}"
    end
  end

  on_linux do
    if Hardware::CPU.arm?
      url "https://github.com/deepnoodle-ai/mobius/releases/download/v{{VERSION}}/mobius-linux-arm64"
      sha256 "{{SHA_LINUX_ARM64}}"
    else
      url "https://github.com/deepnoodle-ai/mobius/releases/download/v{{VERSION}}/mobius-linux-amd64"
      sha256 "{{SHA_LINUX_AMD64}}"
    end
  end

  def install
    binary = Dir["mobius-*"].first || "mobius"
    bin.install binary => "mobius"
  end

  test do
    assert_match "{{VERSION}}", shell_output("#{bin}/mobius --version 2>&1")
  end
end
